# Required: Gemini API key for POST /api/translate
# Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional (Node dev only): outbound proxy for fetches — see src/instrumentation.ts
# HTTP_PROXY=
# HTTPS_PROXY=

# Cloudflare Workers: do not put secrets in this file. Use:
#   npx wrangler secret put GEMINI_API_KEY
